{
  "spec_name": "CLASSIFIER_SPEC",
  "version": "1.0.0",
  "purpose": "Define cómo el Classifier identifica automáticamente vendor, family, firmware y doc_type de un documento fuente",

  "output_contract": {
    "vendor": "string — nombre del vendor detectado",
    "family": "string — familia de equipo detectada",
    "firmware": "string|null — versión de firmware si detectable",
    "doc_type": "enum — tipo de documento",
    "confidence": "decimal 0-1 — confianza agregada",
    "status": "enum — classified|partial|unclassified"
  },

  "detection_layers": {
    "description": "Tres capas ejecutan en paralelo. Nunca se detiene en la primera — las tres votan y el resultado es el de mayor confianza agregada.",
    "layers": [
      {
        "layer": 1,
        "name": "filename",
        "base_confidence": 0.6,
        "description": "Regex sobre el nombre del archivo",
        "patterns": {
          "vendor": [
            { "regex": "zte|ZTE", "result": "ZTE" },
            { "regex": "huawei|HUAWEI", "result": "Huawei" },
            { "regex": "vsol|VSOL", "result": "VSOL" }
          ],
          "family": [
            { "regex": "c320|C320|zxa10", "result": "ZXA10 C320" },
            { "regex": "ma5608|MA5608", "result": "MA5608T" },
            { "regex": "v1600g[^s]|V1600G[^S]", "result": "V1600G" },
            { "regex": "v1600gs|V1600GS", "result": "V1600GS" }
          ],
          "firmware": [
            { "regex": "v(\\d+\\.\\d+)", "result": "capture_group_1" }
          ],
          "doc_type": [
            { "regex": "command.ref|cmdref", "result": "command_reference" },
            { "regex": "initial.config|init.cfg", "result": "initial_configuration" },
            { "regex": "mib.spec", "result": "mib_specification" },
            { "regex": "\\.my$|\\.mib$", "result": "mib_file" },
            { "regex": "alarm", "result": "alarm_reference" },
            { "regex": "catalog|product", "result": "product_catalog" },
            { "regex": "hardware.desc", "result": "hardware_description" }
          ]
        }
      },
      {
        "layer": 2,
        "name": "header_text",
        "description": "Extrae las primeras 3 páginas del PDF y busca patrones de texto",
        "patterns": [
          { "text": "ZTE Corporation", "field": "vendor", "value": "ZTE", "weight": 0.3 },
          { "text": "Huawei Technologies", "field": "vendor", "value": "Huawei", "weight": 0.3 },
          { "text": "VSOL", "field": "vendor", "value": "VSOL", "weight": 0.3 },
          { "text": "ZXA10 C320", "field": "family", "value": "ZXA10 C320", "weight": 0.3 },
          { "text": "MA5608T", "field": "family", "value": "MA5608T", "weight": 0.3 },
          { "text": "Command Reference", "field": "doc_type", "value": "command_reference", "weight": 0.3 },
          { "text": "Initial Configuration", "field": "doc_type", "value": "initial_configuration", "weight": 0.3 },
          { "text": "MIB Reference", "field": "doc_type", "value": "mib_specification", "weight": 0.3 },
          { "text": "Alarm Management", "field": "doc_type", "value": "alarm_reference", "weight": 0.3 }
        ]
      },
      {
        "layer": 3,
        "name": "content_fingerprint",
        "description": "Busca OID prefixes, CLI patterns y alarm codes en el contenido del documento",
        "patterns": [
          { "pattern": "1.3.6.1.4.1.3902", "field": "vendor", "value": "ZTE", "weight": 0.35 },
          { "pattern": "1.3.6.1.4.1.2011", "field": "vendor", "value": "Huawei", "weight": 0.35 },
          { "pattern": "1.3.6.1.4.1.34592", "field": "vendor", "value": "VSOL", "weight": 0.35 },
          { "pattern": "interface gpon-onu", "field": "family", "value": "ZXA10 C320", "weight": 0.2 },
          { "pattern": "DEFINITIONS ::= BEGIN", "field": "doc_type", "value": "mib_file", "weight": 0.4 },
          { "pattern": "330\\d{2}", "field": "doc_type", "value": "alarm_reference", "weight": 0.25 }
        ]
      }
    ]
  },

  "doc_types": {
    "mib_file": { "activates": "MIB Extractor" },
    "mib_specification": { "activates": "Entity + OID Extractor" },
    "command_reference": { "activates": "Command Extractor" },
    "initial_configuration": { "activates": "Entity + Dependency Extractor" },
    "product_catalog": { "activates": "Entity + Alarm Extractor" },
    "alarm_reference": { "activates": "Alarm Extractor" },
    "hardware_description": { "activates": "Entity Extractor" }
  },

  "failure_handling": {
    "confidence_below_0.5": {
      "status": "unclassified",
      "action": "Requiere revisión manual, pipeline no continúa con este documento"
    },
    "vendor_detected_but_doc_type_not": {
      "status": "partial",
      "action": "Continúa con extractores genéricos"
    },
    "vendor_not_in_tkc_vendors": {
      "status": "unclassified",
      "action": "Genera mensaje: 'Vendor X no registrado en tkc_vendors. Registre el vendor antes de procesar este documento.'"
    },
    "conflict_between_layers": {
      "resolution": "Gana la capa de mayor peso, se registra en classifier_message"
    }
  },

  "output_to_db": {
    "table": "tkc_documents",
    "fields": {
      "vendor_id": "FK a tkc_vendors",
      "family_id": "FK a tkc_families",
      "firmware_id": "FK a tkc_firmwares o NULL",
      "doc_type": "ENUM detectado",
      "hash": "SHA-256 del archivo binario",
      "status": "classified|partial|unclassified",
      "classifier_output": {
        "type": "JSON",
        "schema": {
          "confidence": "decimal 0-1 — confianza agregada",
          "method": "array<string> — capas que participaron",
          "layers": {
            "filename": { "matched": "boolean", "confidence": "decimal|null", "reason": "string|null" },
            "header_text": { "matched": "boolean", "confidence": "decimal|null", "reason": "string|null" },
            "oid_prefix": { "matched": "boolean", "confidence": "decimal|null", "reason": "string|null" }
          },
          "message": "string|null — diagnóstico de fallo"
        }
      }
    }
  }
}
